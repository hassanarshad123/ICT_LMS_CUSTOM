# Meta Pixel Configuration — Zensbot LMS
# Copy this file to .env.local and fill in real values

# Public pixel ID — exposed to the browser, safe to commit (but still loaded from env)
NEXT_PUBLIC_META_PIXEL_ID=1457809389158201

# Server-side Conversions API access token — SECRET, never expose to browser
# Generate from: https://business.facebook.com/events_manager2/list/pixel/1457809389158201/settings
# Scroll to "Conversions API" section → "Generate access token"
META_CAPI_ACCESS_TOKEN=

# Optional: test event code for verifying CAPI in Events Manager Test Events panel
# Get from: Events Manager → Test Events → "Test server events" section
# Leave empty in production
META_CAPI_TEST_EVENT_CODE=

# Optional: Graph API version (defaults to v25.0)
META_GRAPH_API_VERSION=v25.0

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Master switch for the personalized onboarding animation during the
# "Setting up your LMS" wait screen. Set to "true" to enable the animation,
# "false" to fall back to the original spinner. Acts as a kill switch:
# flipping this in Vercel triggers a ~30s redeploy and instantly reverts UX.
NEXT_PUBLIC_SHOW_ONBOARDING_ANIMATION=false

# ─── Error Tracking (Sentry) ──────────────────────────────────────────────────
# Sentry DSN for client + server error tracking on the landing app.
# Create a new project at https://sentry.io (Next.js platform) and paste the
# DSN here. Leaving this empty disables Sentry (safe for local dev).
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Sentry auth token for source map uploads during build.
# Generate at https://sentry.io → Settings → Auth Tokens → scope: project:releases
SENTRY_AUTH_TOKEN=

# Optional: Sentry org + project slugs for source map uploads
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# Public site key for the Turnstile widget on /onboarding. Get it from
# https://dash.cloudflare.com/?to=/:account/turnstile → select your widget
# → copy "Site Key" (looks like 0x4AAAAA... ~35 chars).
#
# Dev bypass: leave empty or set to 'SKIP' to disable the CAPTCHA widget
# locally. You MUST also empty CF_TURNSTILE_SECRET_KEY in backend/.env,
# otherwise the backend will reject signups with "CAPTCHA required".
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
