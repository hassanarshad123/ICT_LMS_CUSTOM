# Neon Database
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?ssl=require
DATABASE_URL_DIRECT=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?ssl=require

# JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ict-lms-files

# Bunny.net
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=
BUNNY_TOKEN_KEY=

# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_WEBHOOK_SECRET=
ZOOM_CREDENTIAL_ENCRYPTION_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@ictinstitute.com

# App
APP_ENV=development
APP_DEBUG=true
DEVICE_LIMIT=2
