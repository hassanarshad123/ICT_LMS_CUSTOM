# ============================================
# ICT LMS FRONTEND — Environment Variables
# ============================================

# ── BACKEND API ─────────────────────────────────────────────────
# Points to your FastAPI backend.
# Local dev: http://localhost:8000/api/v1
# Production: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── WEBSOCKET ───────────────────────────────────────────────────
# WebSocket URL for real-time features (class status, announcements, session monitor)
# Local dev: ws://localhost:8000
# Production: wss://api.yourdomain.com
NEXT_PUBLIC_WS_URL=ws://localhost:8000
