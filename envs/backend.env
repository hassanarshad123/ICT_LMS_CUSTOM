# ============================================
# ICT LMS BACKEND — Environment Variables
# ============================================
# Fill in every value marked with <GET_FROM_...>
# Run: python scripts/generate_secret.py to generate JWT_SECRET_KEY and ZOOM_CREDENTIAL_ENCRYPTION_KEY
# ============================================

# ── DATABASE (Neon PostgreSQL) ──────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Use the "Pooled" connection string for DATABASE_URL
# Use the "Direct" connection string for DATABASE_URL_DIRECT (used by Alembic migrations)
# Format: postgresql+asyncpg://user:pass@host/dbname?ssl=require
DATABASE_URL=<GET_FROM_NEON_CONSOLE_POOLED>
DATABASE_URL_DIRECT=<GET_FROM_NEON_CONSOLE_DIRECT>

# ── JWT / AUTH ──────────────────────────────────────────────────
# Generate with: python scripts/generate_secret.py (first line of output)
JWT_SECRET_KEY=<GENERATE_WITH_SCRIPT>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────
# Your frontend URL(s). Comma-separated for multiple origins.
# For local dev: http://localhost:3000
# For production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── AWS S3 (file storage for materials & exports) ───────────────
# Get from: AWS Console → IAM → Create User → Create Access Key
# Then create an S3 bucket and put its name below
AWS_ACCESS_KEY_ID=<GET_FROM_AWS_IAM>
AWS_SECRET_ACCESS_KEY=<GET_FROM_AWS_IAM>
AWS_REGION=us-east-1
S3_BUCKET_NAME=ict-lms-files

# ── BUNNY.NET (video hosting for lectures) ──────────────────────
# Get from: https://dash.bunny.net → Stream → API Key (top right)
# Library ID: Stream → your library → Library ID in URL
# CDN Hostname: Stream → your library → Hostnames
# Token Key: Stream → your library → Security → Token Authentication Key
BUNNY_API_KEY=<GET_FROM_BUNNY_DASHBOARD>
BUNNY_LIBRARY_ID=<GET_FROM_BUNNY_STREAM_LIBRARY>
BUNNY_CDN_HOSTNAME=<GET_FROM_BUNNY_STREAM_HOSTNAMES>
BUNNY_TOKEN_KEY=<GET_FROM_BUNNY_STREAM_SECURITY>

# ── ZOOM (live classes) ────────────────────────────────────────
# Get from: https://marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
# Account ID, Client ID, Client Secret are shown after creating the app
# Webhook Secret: Zoom App → Feature → Event Subscriptions → Secret Token
ZOOM_CLIENT_ID=<GET_FROM_ZOOM_MARKETPLACE>
ZOOM_CLIENT_SECRET=<GET_FROM_ZOOM_MARKETPLACE>
ZOOM_ACCOUNT_ID=<GET_FROM_ZOOM_MARKETPLACE>
ZOOM_WEBHOOK_SECRET=<GET_FROM_ZOOM_APP_WEBHOOK>
# Generate with: python scripts/generate_secret.py (second line of output)
ZOOM_CREDENTIAL_ENCRYPTION_KEY=<GENERATE_WITH_SCRIPT>

# ── RESEND (email notifications) ───────────────────────────────
# Get from: https://resend.com → API Keys → Create API Key
# EMAIL_FROM must be a verified domain/email in Resend
RESEND_API_KEY=<GET_FROM_RESEND_DASHBOARD>
EMAIL_FROM=noreply@yourdomain.com

# ── APP ─────────────────────────────────────────────────────────
# development | production
APP_ENV=development
# true | false (enables debug logs and detailed errors)
APP_DEBUG=true
# Max devices a user can be logged in on simultaneously
DEVICE_LIMIT=2
